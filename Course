/**
 * @file PersonHierarchy.h
 * @brief Declaration of the core Person hierarchy classes
 * OOP Concepts: Abstract Classes, Single, and Multi-level Inheritance
 */
#ifndef PERSON_HIERARCHY_H
#define PERSON_HIERARCHY_H

#include <iostream>
#include <string>
#include <vector>

using namespace std;

// Abstract Base Class
class Person {
protected:
    string name;
    string cnic;
    int age;    
    string contact;

public:
    Person(string n, string c, int a, string con);
    virtual ~Person() = default;
    virtual void displayInfo() const = 0; // Pure Virtual Method

    string getName() const { return name; }
};

// Derived Class Level 1
class Student : public Person {
protected:
    string rollNo;
    int semester; 
    double gpa;   

public:
    Student(string n, string c, int a, string con, string r, int sem, double g);
    void displayInfo() const override;
    virtual char calculateGrade() const;

    string getRollNo() const { return rollNo; }
    double getGPA() const { return gpa; }
};

// Multi-level Inheritance (GradStudent : Student : Person)
class GradStudent : public Student {
private:
    string researchTopic;
public:
    GradStudent(string n, string c, int a, string con, string r, int sem, double g, string topic);
    void displayInfo() const override;
};

// Faculty Class
class Faculty : public Person {
private:
    string employeeID;
    string department;
    string designation;

public:
    Faculty(string n, string c, int a, string con, string emp, string dept, string desig);
    void displayInfo() const override;
};

// Staff Class
class Staff : public Person {
private:
    string staffID;
    string role;   
    double salary; 

public:
    Staff(string n, string c, int a, string con, string id, string r, double sal);
    void displayInfo() const override;
};

#endif // PERSON_HIERARCHY_H
